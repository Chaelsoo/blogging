---
import type { MarkdownHeading } from "astro";

type Props = {
  headings: MarkdownHeading[];
};

const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  toc.length > 0 && (
    <>
      {/* Desktop – fixed sidebar to the right of the centred max-w-3xl container */}
      <nav class="toc-sidebar" aria-label="Table of contents">
        <p class="toc-title">On this page</p>
        <ul>
          {toc.map((h) => (
            <li class:list={["toc-item", h.depth === 3 ? "toc-item--sub" : ""]}>
              <a href={"#" + h.slug}>{h.text}</a>
            </li>
          ))}
        </ul>
      </nav>

    </>
  )
}

<style>
  /* ── Shared ─────────────────────────────────────────── */
  .toc-title {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    opacity: 0.5;
    margin-bottom: 0.5rem;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-item {
    margin-bottom: 0.35rem;
    line-height: 1.3;
  }
  .toc-item--sub {
    padding-left: 0.85rem;
  }
  .toc-item a {
    font-size: 0.78rem;
    font-weight: 300;
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.15s;
  }
  .toc-item a:hover {
    opacity: 1;
  }

  /* ── Desktop sidebar ─────────────────────────────────── */
  .toc-sidebar {
    display: none;
  }

  @media (min-width: 1520px) {
    .toc-sidebar {
      display: block;
      position: fixed;
      /* sits just to the right of the centred max-w-3xl (48rem / 2 = 24rem) */
      left: calc(50% + 25rem);
      top: 5rem;
      width: 13rem;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
      padding: 0.75rem 0.75rem 0.75rem 0.85rem;
      border-left: 2px solid currentColor;
      opacity: 0.55;
      transition: opacity 0.2s;
      z-index: 5;
    }
    .toc-sidebar:hover {
      opacity: 1;
    }
  }
</style>
